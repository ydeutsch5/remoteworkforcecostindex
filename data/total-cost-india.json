    "exchangeRateUSD": 96.28,
    "exchangeRateDate": "2026-05-16",
    "lastUpdated": "May 2026",
    "methodology": "Each role reports two fully-loaded employer cost scenarios. The local_scenario uses the local employer base salary from salaries-india.json (Glassdoor/Payscale/Indeed sources). The us_remote_scenario uses the US employer remote base salary from salaries-india.json (Arc.dev or BLS OES May 2024 offshore-discount estimate). Both scenarios apply identical statutory rates and operational costs. EPF calculated at 12% of basic salary (modeled at 40% of gross CTC = 4.8% effective on gross). ESI does not apply; all roles exceed the ₹21,000/month statutory threshold. Gratuity accrual modeled at 4.81% of basic salary (= 1.924% of gross). Equipment amortized over 36 months. Management overhead is an industry-typical estimate (7.5% of base salary) for organizations using managed remote workforce providers."
  },
  "statutoryRates": {
    "EPF": {
      "employerRate": 0.12,
      "wageBase": "Basic salary (employer-defined; modeled at 40% of gross CTC)",
      "effectiveRateOnGross": 0.048,
      "source": "Employees' Provident Fund Organisation — Contribution Rate",
      "sourceUrl": "https://www.epfindia.gov.in/site_docs/PDFs/MiscPDFs/ContributionRate.pdf",
      "accessed": "May 2026"
    },
    "ESI": {
      "employerRate": 0.0325,
      "wageThreshold": 21000,
      "wageThresholdCurrency": "INR",
      "wageThresholdUSD": 218,
      "applicableToThisDataset": false,
      "note": "All roles in this dataset report gross wages exceeding the ₹21,000/month ESI threshold at international remote compensation levels. ESI contributions are therefore not included in total employer cost calculations.",
      "source": "Employees' State Insurance Corporation — Contribution Rates",
      "sourceUrl": "https://esic.gov.in/contribution",
      "accessed": "May 2026"
    },
    "gratuity": {
      "accrualRate": 0.0481,
      "wageBase": "Basic salary (modeled at 40% of gross CTC)",
      "effectiveRateOnGross": 0.01924,
      "note": "Gratuity = 15/26 × basic per year × years of service. Monthly reserve modeled at 4.81% of basic (= 1.924% of gross CTC).",
      "source": "Payment of Gratuity Act 1972 (amended)",
      "sourceUrl": "https://empxtrack.com/blog/esi-pf-statutory-compliance/",
      "accessed": "May 2026"
    },
    "professionalTax": {
      "note": "Professional tax is state-levied. Karnataka and Maharashtra (the two largest hubs for India remote workers) impose a maximum of ₹2,400/year (₹200/month). Modeled at ₹200/month for all roles.",
      "monthlyUSD": 2.08,
      "source": "Greythr — Decoding PF, ESI and Gratuity Regulations",
      "sourceUrl": "https://www.greythr.com/blog/decoding-pf-esi-and-gratuity-regulations/",
      "accessed": "May 2026"
    }
  },
  "additionalCosts": {
    "equipmentAmortized": {
      "monthlyUSD": 45,
      "components": "Laptop (~$700–$850), monitor (~$160), keyboard/mouse (~$60), headset (~$60), webcam/mic (~$60). Amortized over 36 months.",
      "note": "Sourced from Dell India and Lenovo India pricing, accessed May 2026."
    },
    "internetStipend": {
      "monthlyUSD": 15,
      "note": "Typical employer reimbursement for broadband internet for remote workers in India."
    },
    "managementOverheadEstimate": {
      "rate": "7.5% of base salary",
      "rateForCalculation": 0.075,
      "note": "Industry-typical estimate for organizations that use managed remote workforce providers. This is not a quoted rate from any specific provider. Organizations managing workers directly incur equivalent costs in HR, payroll administration, compliance, and onboarding overhead."
    },
    "trainingOnboardingReserve": {
      "monthlyUSD": 25,
      "annualizedUSD": 300,
      "note": "Annual reserve of $300 for onboarding materials, software licenses, and role-specific training. Spread monthly."
    }
